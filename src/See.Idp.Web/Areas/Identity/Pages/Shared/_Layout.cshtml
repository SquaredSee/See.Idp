@using Microsoft.AspNetCore.Identity
@using See.Idp.Infrastructure
@inject SignInManager<ApplicationUser> SignInManager

<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>@ViewData["Title"] - See.Idp</title>
  <script type="importmap"></script>
  <link rel="stylesheet" href="~/css/identity.out.css" asp-append-version="true" />
</head>

<body>
  <header class="border-b border-border-soft bg-surface/95">
    <div class="mx-auto flex w-full max-w-3xl items-center justify-between px-6 py-4">
      <a asp-area="" asp-page="/Index" class="font-semibold no-underline">See.Idp</a>
      <div class="flex items-center gap-4 text-sm">
        @if (SignInManager.IsSignedIn(User))
        {
          <a asp-area="Identity" asp-page="/Account/Manage/Index">My Account</a>
          <form method="post" asp-area="Identity" asp-page="/Account/Logout"
                asp-route-returnUrl="@Url.Page("/Index", new { area = "" })">
            <button type="submit" class="btn-secondary py-1! px-3!">Sign out</button>
          </form>
        }
        else
        {
          <a asp-area="Identity" asp-page="/Account/Login">Sign in</a>
          <a asp-area="Identity" asp-page="/Account/Register" class="btn-primary py-1! px-3! no-underline">Register</a>
        }
      </div>
    </div>
  </header>

  <main class="page-wrap">
    @RenderBody()
  </main>

  <footer class="border-t border-border-soft">
    <div class="mx-auto w-full max-w-3xl px-6 py-4 text-sm">
      &copy; 2026 - See.Idp - <a asp-area="" asp-page="/Privacy">Privacy</a>
    </div>
  </footer>

  <script src="~/lib/jquery/dist/jquery.min.js"></script>
  @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
