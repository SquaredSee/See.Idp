@page
@model ResetAuthenticatorModel
@{
  ViewData["Title"] = "Reset authenticator";
  Layout = "./_Layout";
}

<div class="panel">
  <h1 class="mb-4">Reset authenticator app</h1>

  <div class="alert-warning mb-6">
    <strong>Warning:</strong> Resetting your authenticator key will disable 2FA until you
    re-enrol with your app. Your existing recovery codes will also be invalidated.
  </div>

  <form method="post">
    <button type="submit" class="btn-danger">Reset authenticator</button>
    <a asp-page="./TwoFactorAuthentication" class="btn-secondary ml-2">Cancel</a>
  </form>
</div>
