@page
@model ChangePasswordModel
@{
  ViewData["Title"] = "Change password";
  Layout = "./_Layout";
}

<div class="panel">
  <h1 class="mb-6">Change password</h1>

  @if (Model.StatusMessage is not null)
  {
    <div
      class="mb-4 rounded-lg border @(Model.StatusMessage.StartsWith("Error") ? "border-red-200 bg-red-50 text-red-700" : "border-green-200 bg-green-50 text-green-700") p-3 text-sm">
      @Model.StatusMessage
    </div>
  }

  <form method="post">
    <div asp-validation-summary="ModelOnly" role="alert"
         class="mb-4 rounded-lg border border-red-200 bg-red-50 p-3 text-sm text-red-700"></div>

    <div class="mb-4">
      <label asp-for="Input.OldPassword" class="field-label">Current password</label>
      <input asp-for="Input.OldPassword" class="field-input" autocomplete="current-password" />
      <span asp-validation-for="Input.OldPassword" class="mt-1 block text-xs text-red-600"></span>
    </div>

    <div class="mb-4">
      <label asp-for="Input.NewPassword" class="field-label">New password</label>
      <input asp-for="Input.NewPassword" class="field-input" autocomplete="new-password" />
      <span asp-validation-for="Input.NewPassword" class="mt-1 block text-xs text-red-600"></span>
    </div>

    <div class="mb-6">
      <label asp-for="Input.ConfirmPassword" class="field-label">Confirm new password</label>
      <input asp-for="Input.ConfirmPassword" class="field-input" autocomplete="new-password" />
      <span asp-validation-for="Input.ConfirmPassword" class="mt-1 block text-xs text-red-600"></span>
    </div>

    <button type="submit" class="btn-primary">Update password</button>
  </form>
</div>

@section Scripts {
  <partial name="_ValidationScriptsPartial" />
}
