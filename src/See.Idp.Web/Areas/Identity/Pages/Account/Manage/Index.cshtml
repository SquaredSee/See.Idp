@page
@model IndexModel
@{
  ViewData["Title"] = "Profile";
  Layout = "./_Layout";
}

<div class="panel">
  <h1 class="mb-6">Profile</h1>

  @if (Model.StatusMessage is not null)
  {
    <div
      class="mb-4 rounded-lg border @(Model.StatusMessage.StartsWith("Error") ? "border-red-200 bg-red-50 text-red-700" : "border-green-200 bg-green-50 text-green-700") p-3 text-sm">
      @Model.StatusMessage
    </div>
  }

  <form method="post">
    <div asp-validation-summary="ModelOnly"
         class="mb-4 rounded-lg border border-red-200 bg-red-50 p-3 text-sm text-red-700"></div>

    <div class="mb-4">
      <label class="field-label">Email</label>
      <input value="@Model.Username" class="field-input bg-slate-50 text-slate-500" disabled />
      <p class="mt-1 text-xs text-slate-500">Email cannot be changed here.</p>
    </div>

    <div class="mb-6">
      <label asp-for="Input.PhoneNumber" class="field-label">Phone number</label>
      <input asp-for="Input.PhoneNumber" class="field-input" autocomplete="tel" />
      <span asp-validation-for="Input.PhoneNumber" class="mt-1 block text-xs text-red-600"></span>
    </div>

    <button type="submit" class="btn-primary">Save changes</button>
  </form>
</div>

@section Scripts {
  <partial name="_ValidationScriptsPartial" />
}
