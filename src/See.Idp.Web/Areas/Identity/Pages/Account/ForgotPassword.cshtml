@page
@model ForgotPasswordModel
@{
  ViewData["Title"] = "Forgot password";
}

<div class="mx-auto max-w-sm">
  <div class="panel">
    <h1 class="mb-2">Forgot your password?</h1>
    <p class="mb-6 text-sm">Enter your email and we'll send you a reset link.</p>

    <form method="post">
      <div asp-validation-summary="ModelOnly"
           class="mb-4 rounded-lg border border-red-200 bg-red-50 p-3 text-sm text-red-700"></div>

      <div class="mb-6">
        <label asp-for="Input.Email" class="field-label">Email</label>
        <input asp-for="Input.Email" class="field-input" autocomplete="username" />
        <span asp-validation-for="Input.Email" class="mt-1 block text-xs text-red-600"></span>
      </div>

      <button type="submit" class="btn-primary w-full">Send reset link</button>
    </form>

    @if (Model.ResetPasswordUrl is not null)
    {
      <div class="mt-6 rounded-lg border border-amber-200 bg-amber-50 p-3">
        <p class="mb-2 text-xs font-semibold text-amber-800">Development — no email sender configured. Use this link:</p>
        <a href="@Model.ResetPasswordUrl" class="break-all text-xs">@Model.ResetPasswordUrl</a>
      </div>
    }
  </div>
</div>

@section Scripts {
  <partial name="_ValidationScriptsPartial" />
}
