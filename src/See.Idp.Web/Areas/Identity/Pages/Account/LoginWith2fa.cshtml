@page
@model LoginWith2faModel
@{
  ViewData["Title"] = "Two-factor authentication";
}

<div class="mx-auto max-w-sm">
  <div class="panel">
    <h1 class="mb-2">Two-factor authentication</h1>
    <p class="mb-6 text-sm text-text-muted">Enter the code from your authenticator app.</p>

    <form method="post">
      <div asp-validation-summary="ModelOnly"
           class="mb-4 rounded-lg border border-red-200 bg-red-50 p-3 text-sm text-red-700"></div>

      <div class="mb-4">
        <label asp-for="Input.TwoFactorCode" class="field-label">Authenticator code</label>
        <input asp-for="Input.TwoFactorCode" class="field-input" autocomplete="one-time-code"
               inputmode="numeric" />
        <span asp-validation-for="Input.TwoFactorCode" class="mt-1 block text-xs text-red-600"></span>
      </div>

      <div class="mb-6">
        <label class="flex cursor-pointer items-center gap-2 text-sm">
          <input asp-for="Input.RememberMachine" type="checkbox" />
          @Html.DisplayNameFor(m => m.Input.RememberMachine)
        </label>
      </div>

      <input type="hidden" name="rememberMe" value="@Model.RememberMe" />
      <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
      <button type="submit" class="btn-primary w-full">Sign in</button>
    </form>

    <p class="mt-4 text-center text-sm">
      Don't have your device?
      <a asp-page="./LoginWithRecoveryCode" asp-route-returnUrl="@Model.ReturnUrl">Use a recovery code</a>
    </p>
  </div>
</div>

@section Scripts {
  <partial name="_ValidationScriptsPartial" />
}
