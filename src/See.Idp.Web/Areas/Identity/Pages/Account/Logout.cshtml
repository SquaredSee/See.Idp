@page
@model LogoutModel
@{
  ViewData["Title"] = "Sign out";
}

<div class="mx-auto max-w-sm text-center">
  <div class="panel">
    <h1 class="mb-4">Sign out</h1>
    <p class="mb-6 text-sm">You have been signed out.</p>
    <a asp-area="Identity" asp-page="/Account/Login" class="btn-primary no-underline">Return to sign in</a>
  </div>
</div>
