@page
@model ConfirmEmailModel
@{
  ViewData["Title"] = "Confirm email";
}

<div class="mx-auto max-w-sm">
  <div class="panel text-center">
    <h1 class="mb-4">Email confirmation</h1>
    @if (!Model.Confirmed)
    {
      <p class="mb-6 text-sm">Click the button below to confirm your email address.</p>
      <form method="post">
        <input type="hidden" asp-for="UserId" />
        <input type="hidden" asp-for="Code" />
        <button type="submit" class="btn-primary">Confirm my email</button>
      </form>
    }
    else
    {
      <p class="text-sm">@Model.StatusMessage</p>
      @if (Model.Succeeded)
      {
        <div class="mt-6">
          <a asp-page="./Login" class="btn-primary no-underline">Sign in</a>
        </div>
      }
    }
  </div>
</div>
