@page
@namespace See.Idp.Web.Areas.Admin.Pages.Clients
@model EditModel
@{
  ViewData["Title"] = "Edit client";
}

@section Scripts {
  <script src="~/lib/jquery/dist/jquery.min.js"></script>
  <partial name="_ValidationScriptsPartial" />
}

<div class="panel mx-auto w-full max-w-2xl">
  <h1>Edit client</h1>

  @if (!string.IsNullOrWhiteSpace(Model.RotatedClientSecret))
  {
    <div class="mt-4 rounded-md border border-emerald-300 bg-emerald-50 p-3 text-sm text-emerald-900">
      <p class="font-semibold">Client secret rotated</p>
      <p class="mt-1">Copy this secret now. It is only shown once.</p>
      @if (Model.SecretRotationPromotedClient)
      {
        <p class="mt-1">This client was promoted to confidential to support secret-based authentication.</p>
      }
      <input value="@Model.RotatedClientSecret" class="field-input mt-2 font-mono" readonly />
    </div>
  }

  <form method="post" class="mt-6 space-y-4">
    <input asp-for="Input.ClientId" type="hidden" />

    <div>
      <label class="field-label">Client ID</label>
      <input value="@Model.Input.ClientId" class="field-input" readonly />
    </div>

    <div>
      <label asp-for="Input.DisplayName" class="field-label"></label>
      <input asp-for="Input.DisplayName" class="field-input" />
      <span asp-validation-for="Input.DisplayName" class="mt-1 block text-sm text-red-600"></span>
    </div>

    <fieldset class="space-y-2 rounded-md border border-border-soft p-3">
      <legend class="field-label mb-0">Allowed flows</legend>

      <label class="flex items-center gap-2 text-sm">
        <input asp-for="Input.AllowAuthorizationCodeFlow" class="h-4 w-4" />
        <span>Authorization code</span>
      </label>

      <label class="flex items-center gap-2 text-sm">
        <input asp-for="Input.AllowClientCredentialsFlow" class="h-4 w-4" />
        <span>Client credentials</span>
      </label>

      <label class="flex items-center gap-2 text-sm">
        <input asp-for="Input.AllowRefreshTokenFlow" class="h-4 w-4" />
        <span>Refresh token</span>
      </label>
    </fieldset>

    <div>
      <label asp-for="Input.RedirectUrisText" class="field-label"></label>
      <textarea asp-for="Input.RedirectUrisText" class="field-input" rows="4"></textarea>
      <p class="mt-1 text-xs text-slate-600">Enter one absolute URI per line.</p>
      <span asp-validation-for="Input.RedirectUrisText" class="mt-1 block text-sm text-red-600"></span>
    </div>

    <div>
      <label asp-for="Input.PermissionsText" class="field-label"></label>
      <textarea asp-for="Input.PermissionsText" class="field-input" rows="6"></textarea>
      <p class="mt-1 text-xs text-slate-600">Advanced mode: enter one OpenIddict permission per line.</p>
      <span asp-validation-for="Input.PermissionsText" class="mt-1 block text-sm text-red-600"></span>
    </div>

    <div asp-validation-summary="ModelOnly" class="text-sm text-red-600"></div>

    <div class="flex items-center gap-3 pt-2">
      <button type="submit" class="btn-primary">Save</button>
      <a asp-page="/Clients/Index" asp-area="Admin" class="text-sm">Cancel</a>
    </div>
  </form>

  <section class="mt-4 space-y-2 border-t border-border-soft pt-4">
    <h2 class="field-label">Client secret</h2>
    <p class="text-xs text-slate-600">
      Existing client secrets are never displayed. Generate a new one to rotate credentials.
    </p>
    <p class="text-xs text-slate-600">
      Current client type:
      <strong>@(Model.Input.IsConfidential ? "Confidential" : "Public")</strong>
      @if (!Model.Input.HasClientSecret)
      {
        <span>(no secret configured)</span>
      }
    </p>

    <form method="post" asp-page-handler="RotateSecret" class="pt-2">
      <input type="hidden" name="Input.ClientId" value="@Model.Input.ClientId" />
      <button type="submit" class="btn-danger">
        @(Model.Input.HasClientSecret ? "Rotate client secret" : "Generate client secret")
      </button>
    </form>
  </section>
</div>
