@page
@namespace See.Idp.Web.Areas.Admin.Pages.Clients
@model IndexModel
@{
  ViewData["Title"] = "Clients";
}

<div class="panel space-y-5">
  <div class="flex items-center justify-between">
    <h1>Clients</h1>
    <div class="flex items-center gap-4">
      <a asp-page="/Clients/Create" asp-area="Admin" class="btn-primary text-sm no-underline">Create client</a>
    </div>
  </div>

  @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
  {
    var statusClasses = Model.StatusKind == "error"
      ? "alert-error"
      : "alert-success";

    <div class="@statusClasses">@Model.StatusMessage</div>
  }

  <div class="overflow-x-auto">
  <table class="table-admin">
    <thead>
      <tr>
        <th>Client ID</th>
        <th>Display Name</th>
        <th class="w-1">Actions</th>
      </tr>
    </thead>
    <tbody>
      @foreach (var client in Model.Clients)
      {
        <tr>
          <td>@client.ClientId</td>
          <td>@client.DisplayName</td>
          <td>
            <div class="flex items-center gap-2">
              <a asp-page="/Clients/Edit" asp-area="Admin" asp-route-clientId="@client.ClientId"
                 class="btn-primary text-sm no-underline">
                Edit
              </a>

              <form method="post" asp-page-handler="Delete">
                <input type="hidden" name="clientId" value="@client.ClientId" />
                <input type="hidden" name="pageNumber" value="@Model.CurrentPage" />
                <button type="submit" class="btn-danger text-sm">Delete</button>
              </form>
            </div>
          </td>
        </tr>
      }
    </tbody>
  </table>
  </div>

  <div class="flex items-center justify-between border-t border-border-soft pt-4">
    <div class="text-sm text-muted">Showing @Model.Clients.Count clients on this page</div>
    <div class="flex items-center gap-2">
      @if (Model.HasPreviousPage)
      {
        <a asp-route-pageNumber="@(Model.CurrentPage - 1)" class="btn-primary text-xs no-underline">
          Previous
        </a>
      }
      else
      {
        <button type="button" disabled class="btn-primary text-xs opacity-50 cursor-not-allowed">Previous</button>
      }

      <span class="text-sm text-muted">Page @Model.CurrentPage</span>

      @if (Model.HasNextPage)
      {
        <a asp-route-pageNumber="@(Model.CurrentPage + 1)" class="btn-primary text-xs no-underline">
          Next
        </a>
      }
      else
      {
        <button type="button" disabled class="btn-primary text-xs opacity-50 cursor-not-allowed">Next</button>
      }
    </div>
  </div>
</div>
