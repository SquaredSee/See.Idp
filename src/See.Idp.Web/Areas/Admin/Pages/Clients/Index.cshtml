@page
@namespace See.Idp.Web.Areas.Admin.Pages.Clients
@model IndexModel
@{
    ViewData["Title"] = "Clients";
}

<div class="panel space-y-5">
    <div class="flex items-center justify-between">
        <h1>Clients</h1>
        <a asp-page="/Clients/Create" asp-area="Admin" class="btn-primary text-sm no-underline">Create client</a>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        var statusClasses = Model.StatusKind == "error"
            ? "rounded-md border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-700"
            : "rounded-md border border-emerald-200 bg-emerald-50 px-3 py-2 text-sm text-emerald-700";

        <div class="@statusClasses">@Model.StatusMessage</div>
    }

    <table class="table-admin">
        <thead>
            <tr>
                <th>Client ID</th>
                <th>Display Name</th>
                <th class="w-1">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var client in Model.Clients)
            {
                <tr>
                    <td>@client.ClientId</td>
                    <td>@client.DisplayName</td>
                    <td>
                        <div class="flex items-center gap-2">
                            <a asp-page="/Clients/Edit" asp-area="Admin" asp-route-clientId="@client.ClientId"
                                   class="btn-primary text-sm no-underline">
                                Edit
                            </a>

                            <form method="post" asp-page-handler="Delete">
                                <input type="hidden" name="clientId" value="@client.ClientId" />
                                <button type="submit" class="btn-danger text-sm">Delete</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>