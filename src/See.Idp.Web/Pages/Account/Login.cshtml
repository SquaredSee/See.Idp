@page
@model See.Idp.Web.Pages.Account.LoginModel

@section Scripts {
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
}

<div class="panel mx-auto w-full max-w-lg">
    <h2>Sign in</h2>

    <form method="post" class="mt-6 space-y-4">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="ReturnUrl" />

        <div>
            <label asp-for="Input.Email" class="field-label">Email</label>
            <input asp-for="Input.Email" type="email" autocomplete="email" class="field-input" />
            <span asp-validation-for="Input.Email" class="mt-1 block text-sm text-red-600"></span>
        </div>

        <div>
            <label asp-for="Input.Password" class="field-label">Password</label>
            <input asp-for="Input.Password" type="password" autocomplete="current-password" class="field-input" />
            <span asp-validation-for="Input.Password" class="mt-1 block text-sm text-red-600"></span>
        </div>

        <div class="flex items-center gap-2">
            <input asp-for="Input.RememberMe" type="checkbox"
                   class="h-4 w-4 rounded border-border-soft text-brand-600" />
            <label asp-for="Input.RememberMe" class="text-sm">Remember me</label>
        </div>

        <div asp-validation-summary="All" class="rounded-lg border border-red-200 bg-red-50 p-3 text-sm text-red-700">
        </div>

        <button type="submit" class="btn-primary w-full">Sign in</button>
    </form>
</div>